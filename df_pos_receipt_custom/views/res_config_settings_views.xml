<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.df.pos.receipt</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_bills_and_receipts_section']" position="after">
                <block title="Receipt Customization" id="pos_receipt_customization_section">
                    <setting string="Receipt Template" help="Select a custom receipt template to control the layout and content of printed and emailed receipts.">
                        <field name="pos_receipt_template_id"/>
                        <div class="mt8">
                            <button name="%(pos_receipt_template_action)d"
                                    type="action"
                                    string="Manage Receipt Templates"
                                    class="btn-link"
                                    icon="fa-external-link"/>
                        </div>
                    </setting>
                    <setting string="Receipt Email Template" help="Select a custom email template for receipt emails. Leave empty to use the default Odoo template.">
                        <field name="pos_receipt_email_template_id"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
